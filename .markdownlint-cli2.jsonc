{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/main/schema/markdownlint-cli2-config-schema.json",
  "config": {
    "default": true,
    "MD009": false,
    "MD012": false,
    "MD013": false,
    "MD022": false,
    "MD024": false,
    "MD032": false,
    "MD033": false,
    "MD034": false,
    "MD041": false
  },
  "globs": [
    "README.md",
    "CONTRIBUTING.md",
    "docs/**/*.md",
    ".github/pull_request_template.md",
    "!node_modules/**"
  ]
}
