---
import '../styles/global.css';
const { title = 'Marionette Docs' } = Astro.props;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const key = 'marionette-docs-theme';
        const saved = localStorage.getItem(key);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved ?? (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a href="/marionette/" class="brand">Marionette Docs</a>
      <nav class="site-nav">
        <a href="/marionette/">Home</a>
        <a href="/marionette/components/">Components</a>
        <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">🌙 Dark</button>
      </nav>
    </header>
    <main class="container">
      {Astro.url.pathname.includes('/components/') && !Astro.url.pathname.endsWith('/components/') && (
        <p class="back-link"><a href="../">← Components 一覧へ戻る</a></p>
      )}
      <slot />
    </main>
  </body>
  <style>
    .back-link {
      margin: 0.75rem 0 1rem;
    }

    .back-link a {
      color: var(--sl-color-text-accent);
      text-decoration: none;
      font-weight: 600;
    }
  </style>
  <script is:inline>
    (() => {
      const key = 'marionette-docs-theme';
      const root = document.documentElement;
      const button = document.getElementById('theme-toggle');
      if (!button) return;

      const syncLabel = () => {
        const dark = root.getAttribute('data-theme') === 'dark';
        button.textContent = dark ? '☀️ Light' : '🌙 Dark';
        button.setAttribute('aria-pressed', String(dark));
      };

      button.addEventListener('click', () => {
        const current = root.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        localStorage.setItem(key, next);
        syncLabel();
      });

      syncLabel();
    })();
  </script>
</html>
