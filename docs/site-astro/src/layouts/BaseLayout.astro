---
import '../styles/global.css';
const { title = 'Marionette Docs' } = Astro.props;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/marionette/" class="brand">Marionette Docs</a>
      <nav>
        <a href="/marionette/">Home</a>
        <a href="/marionette/components/">Components</a>
      </nav>
    </header>
    <main class="container">
      {Astro.url.pathname.startsWith('/components/') && Astro.url.pathname !== '/components/' && (
        <p class="back-link"><a href="/components/">← Components 一覧へ戻る</a></p>
      )}
      <slot />
    </main>
  </body>
  <style>
    .back-link {
      margin: 0.75rem 0 1rem;
    }

    .back-link a {
      color: var(--sl-color-text-accent);
      text-decoration: none;
      font-weight: 600;
    }
  </style>
</html>
