---
import '../styles/global.css';

const {
  title = 'Marionette Docs',
  lang = 'en',
  languageSwitcherPath = '/marionette/',
} = Astro.props;
const isJa = lang === 'ja';
---
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const key = 'marionette-docs-theme';
        const saved = localStorage.getItem(key);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved ?? (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a href={isJa ? '/marionette/ja/' : '/marionette/en/'} class="brand">Marionette Docs</a>
      <nav class="site-nav">
        <a href={isJa ? '/marionette/ja/' : '/marionette/en/'}>{isJa ? 'ホーム' : 'Home'}</a>
        <a href={isJa ? '/marionette/ja/components/' : '/marionette/en/components/'}>{isJa ? 'コンポーネント' : 'Components'}</a>
        <a href={languageSwitcherPath} hreflang={isJa ? 'en' : 'ja'}>{isJa ? 'English' : '日本語'}</a>
        <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">🌙 Dark</button>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
  <script is:inline>
    (() => {
      const key = 'marionette-docs-theme';
      const root = document.documentElement;
      const button = document.getElementById('theme-toggle');
      if (!button) return;

      const syncLabel = () => {
        const dark = root.getAttribute('data-theme') === 'dark';
        button.textContent = dark ? '☀️ Light' : '🌙 Dark';
        button.setAttribute('aria-pressed', String(dark));
      };

      button.addEventListener('click', () => {
        const current = root.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        localStorage.setItem(key, next);
        syncLabel();
      });

      syncLabel();
    })();
  </script>
</html>
