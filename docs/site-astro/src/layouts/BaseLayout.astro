---
import '../styles/global.css';
import catalog from '../data/components-index.json';
import logo from '../../../assets/logo.png';

const {
  title = 'Marionette Docs',
  lang = 'en',
  languageSwitcherPath = '/marionette/',
} = Astro.props;
const isJa = lang === 'ja';
const currentPath = Astro.url.pathname;
const langRoot = isJa ? '/marionette/ja' : '/marionette/en';

const introItems = isJa
  ? [
      { label: 'ホーム', href: `${langRoot}/` },
    ]
  : [
      { label: 'Home', href: `${langRoot}/` },
    ];

const referenceItems = isJa
  ? [
      { label: 'API Docs', href: `${langRoot}/api/` },
      { label: '検索', href: `${langRoot}/search/` },
    ]
  : [
      { label: 'API Docs', href: `${langRoot}/api/` },
      { label: 'Search', href: `${langRoot}/search/` },
    ];

const tutorialItems = isJa
  ? [
      { label: '最初のアプリを作る', href: `${langRoot}/tutorial/` },
      { label: '静的アセットを配信する', href: `${langRoot}/tutorial/assets/` },
      { label: 'バックエンドとフロントエンドの通信', href: `${langRoot}/tutorial/backend-frontend/` },
    ]
  : [
      { label: 'Build your first app', href: `${langRoot}/tutorial/` },
      { label: 'Serve static assets', href: `${langRoot}/tutorial/assets/` },
      { label: 'Backend and frontend communication', href: `${langRoot}/tutorial/backend-frontend/` },
    ];

const componentById = new Map(catalog.components.map((component) => [component.id, component]));
const componentSectionDefinitions = isJa
  ? [
      { title: 'アクション / リンク', ids: ['button', 'link', 'theme-toggle-button'] },
      { title: 'フォーム / 入力', ids: ['form', 'form-field', 'input', 'select', 'textarea', 'checkbox', 'radio-group', 'switch'] },
      { title: 'ナビゲーション', ids: ['sidebar', 'tabs', 'breadcrumb', 'pagination', 'navigation'] },
      { title: 'フィードバック / オーバーレイ', ids: ['modal', 'toast', 'alert', 'empty-state', 'skeleton', 'progress', 'feedback', 'overlay-system'] },
      { title: 'データ / メディア', ids: ['table', 'dataframe', 'dataframe-chart', 'image'] },
      { title: 'チャート', ids: ['chart', 'chart-line', 'chart-bar', 'chart-pie', 'chart-doughnut', 'chart-scatter'] },
      { title: 'レイアウト', ids: ['stack', 'grid', 'split', 'page-header', 'container', 'card', 'section', 'layout'] },
      { title: 'タイポグラフィ', ids: ['heading', 'paragraph', 'span'] },
    ]
  : [
      { title: 'Actions and links', ids: ['button', 'link', 'theme-toggle-button'] },
      { title: 'Forms and inputs', ids: ['form', 'form-field', 'input', 'select', 'textarea', 'checkbox', 'radio-group', 'switch'] },
      { title: 'Navigation', ids: ['sidebar', 'tabs', 'breadcrumb', 'pagination', 'navigation'] },
      { title: 'Feedback and overlays', ids: ['modal', 'toast', 'alert', 'empty-state', 'skeleton', 'progress', 'feedback', 'overlay-system'] },
      { title: 'Data and media', ids: ['table', 'dataframe', 'dataframe-chart', 'image'] },
      { title: 'Charts', ids: ['chart', 'chart-line', 'chart-bar', 'chart-pie', 'chart-doughnut', 'chart-scatter'] },
      { title: 'Layout surfaces', ids: ['stack', 'grid', 'split', 'page-header', 'container', 'card', 'section', 'layout'] },
      { title: 'Typography', ids: ['heading', 'paragraph', 'span'] },
    ];
const categorizedComponentIds = new Set(componentSectionDefinitions.flatMap((section) => section.ids));
const componentSections = componentSectionDefinitions.map((section) => ({
  ...section,
  items: section.ids.map((id) => componentById.get(id)).filter(Boolean),
})).filter((section) => section.items.length > 0);
const uncategorizedComponents = catalog.components.filter((component) => !categorizedComponentIds.has(component.id));
if (uncategorizedComponents.length > 0) {
  componentSections.push({
    title: isJa ? 'その他' : 'Other components',
    ids: uncategorizedComponents.map((component) => component.id),
    items: uncategorizedComponents,
  });
}
---
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const key = 'marionette-docs-theme';
        const saved = localStorage.getItem(key);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved ?? (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a href={isJa ? '/marionette/ja/' : '/marionette/en/'} class="brand">
        <img src={logo.src} width={logo.width} height={logo.height} alt="" class="brand-logo" />
        <span>Marionette Docs</span>
      </a>
      <nav class="site-nav">
        <a href={languageSwitcherPath} hreflang={isJa ? 'en' : 'ja'}>{isJa ? 'English' : '日本語'}</a>
        <a href="https://github.com/YoshihideShirai/marionette" target="_blank" rel="noreferrer">
          GitHub
        </a>
        <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">🌙 Dark</button>
      </nav>
    </header>
    <main class="docs-shell">
      <aside class="sidebar" aria-label={isJa ? 'ドキュメントナビゲーション' : 'Documentation navigation'}>
        <a class="sidebar-search-link" href={`${langRoot}/search/`}>
          <span>{isJa ? '検索' : 'Search'}</span>
          <kbd>Ctrl K</kbd>
        </a>
        <p class="sidebar-title">{isJa ? 'コンテンツ' : 'Contents'}</p>
        <nav>
          <ul class="sidebar-section-list">
            {introItems.map((item) => {
              const active =
                item.href === `${langRoot}/`
                  ? currentPath === item.href
                  : currentPath === item.href || currentPath.startsWith(item.href);
              return (
                <li>
                  <a href={item.href} class:list={['sidebar-section-link', { active }]} aria-current={active ? 'page' : undefined}>{item.label}</a>
                </li>
              );
            })}

            <li>
              <details class="sidebar-group" open={currentPath.includes('/tutorial')}>
                <summary class:list={{ active: currentPath.includes('/tutorial') }}>{isJa ? 'チュートリアル' : 'Tutorial'}</summary>
                <ul class="sidebar-nested-list">
                  {tutorialItems.map((item) => {
                    const active = currentPath === item.href;
                    return (
                      <li>
                        <a href={item.href} class:list={{ active }} aria-current={active ? 'page' : undefined}>{item.label}</a>
                      </li>
                    );
                  })}
                </ul>
              </details>
            </li>

            <li>
              <details class="sidebar-group" open={currentPath.includes('/components')}>
                <summary class:list={{ active: currentPath.includes('/components') }}>{isJa ? 'コンポーネント' : 'Components'}</summary>
                <label class="sidebar-search">
                  <span class="sr-only">{isJa ? 'コンポーネントを検索' : 'Search components'}</span>
                  <input
                    id="sidebar-component-search"
                    type="search"
                    placeholder={isJa ? 'コンポーネントを検索' : 'Search components'}
                    autocomplete="off"
                  />
                </label>
                <p id="sidebar-search-empty" class="sidebar-search-empty" hidden>{isJa ? '一致する項目がありません。' : 'No matching components.'}</p>
                <ul class="sidebar-component-list">
                  <li>
                    <a
                      href={`${langRoot}/components/`}
                      class:list={{ active: currentPath === `${langRoot}/components/` }}
                      aria-current={currentPath === `${langRoot}/components/` ? 'page' : undefined}
                    >
                      {isJa ? '一覧ページ' : 'Overview'}
                    </a>
                  </li>
                  {componentSections.map((section) => {
                    const items = section.items;
                    const hasActive = items.some((component) => currentPath.startsWith(`${langRoot}/components/${component.id}/`));
                    return (
                      <li data-component-group={section.title.toLowerCase()}>
                        <details open={hasActive}>
                          <summary>{section.title}</summary>
                          <ul>
                            {items.map((component) => {
                              const href = `${langRoot}/components/${component.id}/`;
                              const active = currentPath === href;
                              return (
                                <li data-component-item data-component-name={component.name.toLowerCase()}>
                                  <a href={href} class:list={{ active }} aria-current={active ? 'page' : undefined}>
                                    {component.name}
                                  </a>
                                </li>
                              );
                            })}
                          </ul>
                        </details>
                      </li>
                    );
                  })}
                </ul>
              </details>
            </li>

            {referenceItems.map((item) => {
              const active = currentPath === item.href || currentPath.startsWith(item.href);
              return (
                <li>
                  <a href={item.href} class:list={['sidebar-section-link', { active }]} aria-current={active ? 'page' : undefined}>{item.label}</a>
                </li>
              );
            })}
          </ul>
        </nav>
      </aside>
      <section class="container">
        <slot />
      </section>
    </main>
  </body>
  <script is:inline>
    (() => {
      const key = 'marionette-docs-theme';
      const root = document.documentElement;
      const button = document.getElementById('theme-toggle');
      if (!button) return;

      const syncLabel = () => {
        const dark = root.getAttribute('data-theme') === 'dark';
        button.textContent = dark ? '☀️ Light' : '🌙 Dark';
        button.setAttribute('aria-pressed', String(dark));
      };

      button.addEventListener('click', () => {
        const current = root.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        localStorage.setItem(key, next);
        syncLabel();
      });

      syncLabel();
    })();

    (() => {
      const input = document.getElementById('sidebar-component-search');
      const emptyState = document.getElementById('sidebar-search-empty');
      if (!(input instanceof HTMLInputElement) || !(emptyState instanceof HTMLElement)) return;

      const groups = Array.from(document.querySelectorAll('[data-component-group]'));
      const filter = () => {
        const query = input.value.trim().toLowerCase();
        let visibleCount = 0;

        groups.forEach((groupNode) => {
          const groupItems = Array.from(groupNode.querySelectorAll('[data-component-item]'));
          let groupVisible = 0;

          groupItems.forEach((itemNode) => {
            const name = itemNode.getAttribute('data-component-name') || '';
            const matched = !query || name.includes(query);
            itemNode.hidden = !matched;
            if (matched) {
              groupVisible += 1;
              visibleCount += 1;
            }
          });

          groupNode.hidden = groupVisible === 0;
        });

        emptyState.hidden = visibleCount > 0;
      };

      input.addEventListener('input', filter);
      filter();
    })();

    (() => {
      const frames = Array.from(document.querySelectorAll('iframe'));
      const observers = [];

      const resizeFrame = (frame) => {
        try {
          const doc = frame.contentDocument;
          if (!doc) return;

          const body = doc.body;
          const root = doc.documentElement;
          const height = Math.max(
            body?.scrollHeight || 0,
            body?.offsetHeight || 0,
            root?.scrollHeight || 0,
            root?.offsetHeight || 0,
          );

          if (height > 0) {
            frame.style.height = `${height + 2}px`;
          }
        } catch {
          // Cross-origin frames cannot be measured. Current component examples are same-origin.
        }
      };

      frames.forEach((frame) => {
        frame.setAttribute('scrolling', 'no');

        const attachObserver = () => {
          resizeFrame(frame);

          try {
            const doc = frame.contentDocument;
            if (!doc || !window.ResizeObserver) return;

            const observer = new ResizeObserver(() => resizeFrame(frame));
            if (doc.body) observer.observe(doc.body);
            if (doc.documentElement) observer.observe(doc.documentElement);
            observers.push(observer);
          } catch {
            // Cross-origin frames cannot be observed.
          }
        };

        frame.addEventListener('load', attachObserver);
        if (frame.contentDocument?.readyState === 'complete') {
          attachObserver();
        }
      });

      window.addEventListener('resize', () => {
        frames.forEach(resizeFrame);
      });
    })();
  </script>
</html>
