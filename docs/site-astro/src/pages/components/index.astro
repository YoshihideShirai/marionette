---
import BaseLayout from '../../layouts/BaseLayout.astro';
import catalog from '../../data/components-index.json';

const cards = catalog.components.filter((c) => c.example);
---
<BaseLayout title="Components Gallery">
  <h1>Components Gallery</h1>
  <p class="lead">各コンポーネントのvisualサンプルをiframeで表示します。</p>

  <div class="grid">
    {cards.map((component) => {
      const examplePath = component.example.replace('docs/site/components/examples/', '/marionette/examples/');
      return (
        <article class="card">
          <h2>{component.name}</h2>
          <p>{component.description}</p>
          <iframe src={examplePath} title={`${component.name} example`} loading="lazy" />
        </article>
      );
    })}
  </div>
</BaseLayout>
