---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import catalog from '../../../data/components-index.json';

const cards = catalog.components;
const componentById = new Map(cards.map((component) => [component.id, component]));
const sectionDefinitions = [
  {
    title: 'Layout surfaces',
    description: 'Page structure, containers, sections, and composition primitives.',
    ids: ['container', 'page-header', 'section', 'card', 'stack', 'grid', 'split', 'layout'],
  },
  {
    title: 'Typography',
    description: 'Text primitives and heading helpers.',
    ids: ['heading', 'paragraph', 'span'],
  },
  {
    title: 'Actions and links',
    description: 'Buttons, links, and direct user actions.',
    ids: ['button', 'link', 'theme-toggle-button'],
  },
  {
    title: 'Forms and inputs',
    description: 'Controls for collecting and validating user input.',
    ids: ['form', 'form-field', 'input', 'file-upload', 'textarea', 'select', 'checkbox', 'radio-group', 'switch'],
  },
  {
    title: 'Navigation',
    description: 'Wayfinding, hierarchy, paging, and navigation demos.',
    ids: ['sidebar', 'breadcrumb', 'tabs', 'pagination', 'navigation'],
  },
  {
    title: 'Feedback and overlays',
    description: 'Status, loading, empty states, and layered UI.',
    ids: ['alert', 'toast', 'progress', 'skeleton', 'empty-state', 'modal', 'overlay-system', 'feedback'],
  },
  {
    title: 'Data and media',
    description: 'Tables, data frames, and visual media.',
    ids: ['table', 'image', 'dataframe', 'dataframe-chart'],
  },
  {
    title: 'Charts',
    description: 'Chart wrappers and chart-specific examples.',
    ids: ['chart', 'chart-line', 'chart-bar', 'chart-pie', 'chart-doughnut', 'chart-scatter'],
  },
];
const categorizedIds = new Set(sectionDefinitions.flatMap((section) => section.ids));
const sections = sectionDefinitions.map((section) => ({
  ...section,
  components: section.ids.map((id) => componentById.get(id)).filter(Boolean),
})).filter((section) => section.components.length > 0);
const uncategorized = cards.filter((component) => !categorizedIds.has(component.id));
if (uncategorized.length > 0) {
  sections.push({
    title: 'Other components',
    description: 'Additional examples that do not yet fit one primary category.',
    ids: uncategorized.map((component) => component.id),
    components: uncategorized,
  });
}
---
<BaseLayout title="Components Gallery">
  <div class="component-gallery">
    <header class="component-gallery-header">
      <div>
        <h1>Components Gallery</h1>
        <p class="lead">Displays each component visual sample in an iframe.</p>
      </div>

      <label class="search-field">
        <span>Search components</span>
        <input
          id="component-search"
          type="search"
          placeholder="Filter by name or description"
          autocomplete="off"
        />
      </label>
    </header>

    <div class="component-sections" data-component-sections>
      {sections.map((section) => (
        <section class="component-section" data-component-section>
          <header class="section-header">
            <div>
              <h2>{section.title}</h2>
              <p>{section.description}</p>
            </div>
            <span>{section.components.length}</span>
          </header>
          <div class="component-grid">
            {section.components.map((component) => (
              <article
                class="card component-card"
                data-component-card
                data-name={component.name.toLowerCase()}
                data-description={component.description.toLowerCase()}
              >
                <header class="card-header">
                  <h3><a href={`./${component.id}/`}>{component.name}</a></h3>
                  {!component.example && <span class="badge">Example pending</span>}
                </header>
                <p>{component.description}</p>
                {component.example && (
                  <iframe src={component.example} title={`${component.name} example`} loading="lazy" />
                )}
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>

    <p class="empty" data-empty-state hidden>No components matched your search.</p>
  </div>

  <script>
    const input = document.querySelector('#component-search');
    const cards = Array.from(document.querySelectorAll('[data-component-card]'));
    const sections = Array.from(document.querySelectorAll('[data-component-section]'));
    const emptyState = document.querySelector('[data-empty-state]');

    const applySearch = () => {
      const keyword = (input?.value ?? '').trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const name = card.dataset.name ?? '';
        const description = card.dataset.description ?? '';
        const keywordMatches = !keyword || name.includes(keyword) || description.includes(keyword);
        const isMatch = keywordMatches;
        card.hidden = !isMatch;
        if (isMatch) visibleCount += 1;
      });

      sections.forEach((section) => {
        const sectionCards = Array.from(section.querySelectorAll('[data-component-card]'));
        section.hidden = !sectionCards.some((card) => !card.hidden);
      });

      if (emptyState) {
        emptyState.hidden = visibleCount > 0;
      }
    };

    input?.addEventListener('input', applySearch);
    applySearch();
  </script>

  <style>
    .component-gallery {
      display: grid;
      gap: 1.25rem;
    }

    .component-gallery-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(18rem, 28rem);
      gap: 1rem;
      align-items: end;
    }

    .component-gallery-header h1 {
      margin-bottom: 0.35rem;
    }

    .search-field {
      display: grid;
      gap: 0.4rem;
      min-width: 0;
    }

    .search-field input {
      width: 100%;
      padding: 0.55rem 0.7rem;
      border-radius: 0.5rem;
      border: 1px solid var(--line);
      background: var(--surface);
      color: var(--fg);
      font: inherit;
    }

    .search-field input::placeholder {
      color: var(--muted);
    }

    .search-field input:focus {
      border-color: var(--accent);
      outline: 2px solid color-mix(in srgb, var(--accent) 24%, transparent);
      outline-offset: 1px;
    }

    .component-sections {
      display: grid;
      gap: 2rem;
    }

    .component-section {
      display: grid;
      gap: 0.85rem;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: end;
      border-bottom: 1px solid var(--line);
      padding-bottom: 0.6rem;
    }

    .section-header h2 {
      margin: 0 0 0.25rem;
      font-size: 1.2rem;
    }

    .section-header p {
      margin: 0;
      color: var(--muted);
    }

    .section-header span {
      color: var(--muted);
      font-size: 0.9rem;
      white-space: nowrap;
    }

    .component-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
      gap: 1rem;
      align-items: stretch;
    }

    .component-card {
      display: grid;
      grid-template-rows: auto auto minmax(16rem, 1fr);
      gap: 0.75rem;
      min-width: 0;
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      gap: 0.5rem;
      align-items: center;
    }

    .card-header h3 {
      margin: 0;
      font-size: 1.1rem;
      line-height: 1.3;
    }

    .component-card p {
      margin: 0;
      color: var(--muted);
    }

    .component-card iframe {
      width: 100%;
      min-height: 16rem;
      height: 100%;
    }

    .badge {
      border: 1px solid color-mix(in srgb, #f97316 70%, var(--line));
      background: color-mix(in srgb, #f97316 12%, transparent);
      color: color-mix(in srgb, #f97316 85%, var(--fg));
      border-radius: 999px;
      padding: 0.2rem 0.55rem;
      font-size: 0.75rem;
      white-space: nowrap;
    }

    .empty {
      margin-top: 1rem;
      color: var(--muted);
    }

    @media (max-width: 760px) {
      .component-gallery-header {
        grid-template-columns: 1fr;
        align-items: stretch;
      }
    }
  </style>
</BaseLayout>
