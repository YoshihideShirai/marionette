---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import catalog from '../../../data/components-index.json';

const cards = catalog.components;
const groups = ['Components', 'Layout', 'Data', 'Chart'] as const;
const selectedGroup = Astro.url.searchParams.get('group');
const initialGroup = groups.includes(selectedGroup as (typeof groups)[number]) ? selectedGroup : 'All';
---
<BaseLayout title="Components Gallery">
  <div class="component-gallery">
    <header class="component-gallery-header">
      <div>
        <h1>Components Gallery</h1>
        <p class="lead">Displays each component visual sample in an iframe.</p>
      </div>

      <label class="search-field">
        <span>Search components</span>
        <input
          id="component-search"
          type="search"
          placeholder="Filter by name or description"
          autocomplete="off"
        />
      </label>
    </header>

    <nav class="group-filter" aria-label="Component group filter">
      {['All', ...groups].map((group) => {
        const href = group === 'All' ? './' : `./?group=${encodeURIComponent(group)}`;
        const active = group === initialGroup;

        return (
          <a href={href} class:list={{ chip: true, active }} aria-current={active ? 'page' : undefined} data-group-filter={group}>
            {group}
          </a>
        );
      })}
    </nav>

    <div class="component-grid" data-component-grid>
      {cards.map((component) => {
        return (
          <article
            class="card component-card"
            data-component-card
            data-group={component.group}
            data-name={component.name.toLowerCase()}
            data-description={component.description.toLowerCase()}
          >
            <header class="card-header">
              <h2><a href={`./${component.id}/`}>{component.name}</a></h2>
              {!component.example && <span class="badge">Example pending</span>}
            </header>
            <p>{component.description}</p>
            {component.example && (
              <iframe src={component.example} title={`${component.name} example`} loading="lazy" />
            )}
          </article>
        );
      })}
    </div>

    <p class="empty" data-empty-state hidden>No components matched your search.</p>
  </div>

  <script>
    const input = document.querySelector('#component-search');
    const cards = Array.from(document.querySelectorAll('[data-component-card]'));
    const emptyState = document.querySelector('[data-empty-state]');
    const groupFilters = Array.from(document.querySelectorAll('[data-group-filter]'));
    const validGroups = new Set(groupFilters.map((filter) => filter.dataset.groupFilter));

    const getSelectedGroup = () => {
      const group = new URLSearchParams(window.location.search).get('group') || 'All';
      return validGroups.has(group) ? group : 'All';
    };

    const setActiveGroup = (selectedGroup) => {
      groupFilters.forEach((filter) => {
        const active = filter.dataset.groupFilter === selectedGroup;
        filter.classList.toggle('active', active);
        if (active) {
          filter.setAttribute('aria-current', 'page');
        } else {
          filter.removeAttribute('aria-current');
        }
      });
    };

    const applySearch = () => {
      const keyword = (input?.value ?? '').trim().toLowerCase();
      const selectedGroup = getSelectedGroup();
      let visibleCount = 0;

      cards.forEach((card) => {
        const name = card.dataset.name ?? '';
        const description = card.dataset.description ?? '';
        const group = card.dataset.group ?? '';
        const groupMatches = selectedGroup === 'All' || group === selectedGroup;
        const keywordMatches = !keyword || name.includes(keyword) || description.includes(keyword);
        const isMatch = groupMatches && keywordMatches;
        card.hidden = !isMatch;
        if (isMatch) visibleCount += 1;
      });

      setActiveGroup(selectedGroup);

      if (emptyState) {
        emptyState.hidden = visibleCount > 0;
      }
    };

    groupFilters.forEach((filter) => {
      filter.addEventListener('click', (event) => {
        event.preventDefault();
        const group = filter.dataset.groupFilter || 'All';
        const url = new URL(window.location.href);
        if (group === 'All') {
          url.searchParams.delete('group');
        } else {
          url.searchParams.set('group', group);
        }
        window.history.pushState({}, '', url);
        applySearch();
      });
    });

    window.addEventListener('popstate', applySearch);
    input?.addEventListener('input', applySearch);
    applySearch();
  </script>

  <style>
    .component-gallery {
      display: grid;
      gap: 1rem;
    }

    .component-gallery-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(18rem, 28rem);
      gap: 1rem;
      align-items: end;
    }

    .component-gallery-header h1 {
      margin-bottom: 0.35rem;
    }

    .group-filter {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 0;
    }

    .chip {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 0.35rem 0.8rem;
      text-decoration: none;
      font-size: 0.9rem;
      color: inherit;
    }

    .chip.active {
      border-color: var(--accent);
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      color: var(--accent);
    }

    .search-field {
      display: grid;
      gap: 0.4rem;
      min-width: 0;
    }

    .search-field input {
      width: 100%;
      padding: 0.55rem 0.7rem;
      border-radius: 0.5rem;
      border: 1px solid var(--line);
      background: var(--surface);
      color: var(--fg);
      font: inherit;
    }

    .search-field input::placeholder {
      color: var(--muted);
    }

    .search-field input:focus {
      border-color: var(--accent);
      outline: 2px solid color-mix(in srgb, var(--accent) 24%, transparent);
      outline-offset: 1px;
    }

    .component-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
      gap: 1rem;
      align-items: stretch;
    }

    .component-card {
      display: grid;
      grid-template-rows: auto auto minmax(16rem, 1fr);
      gap: 0.75rem;
      min-width: 0;
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      gap: 0.5rem;
      align-items: center;
    }

    .card-header h2 {
      margin: 0;
      font-size: 1.1rem;
      line-height: 1.3;
    }

    .component-card p {
      margin: 0;
      color: var(--muted);
    }

    .component-card iframe {
      width: 100%;
      min-height: 16rem;
      height: 100%;
    }

    .badge {
      border: 1px solid color-mix(in srgb, #f97316 70%, var(--line));
      background: color-mix(in srgb, #f97316 12%, transparent);
      color: color-mix(in srgb, #f97316 85%, var(--fg));
      border-radius: 999px;
      padding: 0.2rem 0.55rem;
      font-size: 0.75rem;
      white-space: nowrap;
    }

    .empty {
      margin-top: 1rem;
      color: var(--muted);
    }

    @media (max-width: 760px) {
      .component-gallery-header {
        grid-template-columns: 1fr;
        align-items: stretch;
      }
    }
  </style>
</BaseLayout>
