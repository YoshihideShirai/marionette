---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const helloWorldCode = `package main

import (
    mb "github.com/YoshihideShirai/marionette/backend"
    mf "github.com/YoshihideShirai/marionette/frontend"
)

func main() {
    app := mb.New()

    app.Page("/", func(ctx *mb.Context) mf.Node {
        return mf.UIContainer(mf.ContainerProps{
            MaxWidth: "2xl",
            Centered: true,
        },
            mf.Stack(mf.StackProps{Direction: "column", Gap: "4"},
                mf.PageHeader(mf.PageHeaderProps{
                    Title:       "Hello, Marionette",
                    Description: "Your first Go-powered UI is running.",
                }),
                mf.TextComponent(mf.TextProps{
                    Text: "Hello World",
                    Size: "lg",
                }),
            ),
        )
    })

    if err := app.Run("127.0.0.1:8080"); err != nil {
        panic(err)
    }
}`;
---
<BaseLayout title="Tutorial - Marionette" lang="en" languageSwitcherPath="/marionette/ja/tutorial/">
  <article class="training-doc">
    <header>
      <p class="eyebrow">Tutorial</p>
      <h1>Build Your First Marionette App</h1>
      <p class="lead">
        Create an empty Go project, add Marionette, and render Hello World in the browser step by step.
      </p>
    </header>

    <section class="lesson-step" aria-labelledby="before-you-start-en">
      <p class="step-label">Step 1</p>
      <h2 id="before-you-start-en">Check Your Setup</h2>
      <p>Make sure Go is installed and available from your terminal.</p>
      <pre><code>go version</code></pre>
    </section>

    <section class="lesson-step" aria-labelledby="create-project-en">
      <p class="step-label">Step 2</p>
      <h2 id="create-project-en">Create a Project</h2>
      <p>Create a working directory and initialize a Go module.</p>
      <pre><code>mkdir marionette-hello
cd marionette-hello
go mod init example.com/marionette-hello</code></pre>
    </section>

    <section class="lesson-step" aria-labelledby="add-marionette-en">
      <p class="step-label">Step 3</p>
      <h2 id="add-marionette-en">Add Marionette</h2>
      <p>Add Marionette as a dependency.</p>
      <pre><code>go get github.com/YoshihideShirai/marionette@latest</code></pre>
    </section>

    <section class="lesson-step" aria-labelledby="write-app-en">
      <p class="step-label">Step 4</p>
      <h2 id="write-app-en">Write Hello World</h2>
      <p>Create <code>main.go</code> with this code.</p>
      <pre><code>{helloWorldCode}</code></pre>
    </section>

    <section class="lesson-step" aria-labelledby="run-app-en">
      <p class="step-label">Step 5</p>
      <h2 id="run-app-en">Run and Open It</h2>
      <p>Start the app.</p>
      <pre><code>go run .</code></pre>
      <p>Open <a href="http://127.0.0.1:8080">http://127.0.0.1:8080</a> in your browser.</p>
    </section>

    <section class="lesson-step" aria-labelledby="learned-en">
      <p class="step-label">Step 6</p>
      <h2 id="learned-en">What You Learned</h2>
      <ul>
        <li>Create a Marionette app with <code>mb.New()</code></li>
        <li>Register a page with <code>app.Page</code></li>
        <li>Compose the screen with <code>frontend</code> components</li>
        <li>Start a local server with <code>app.Run</code></li>
      </ul>
      <p>Next, learn <a href="/marionette/en/tutorial/backend-frontend/">how the backend communicates with the frontend</a>.</p>
    </section>
  </article>
</BaseLayout>
