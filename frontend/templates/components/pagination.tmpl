{{define "components/pagination"}}
<div class="flex items-center justify-end gap-3 px-4 py-3">
  {{if .PrevHref}}
  <a href="{{.PrevHref}}" class="btn btn-ghost btn-sm">Prev</a>
  {{else}}
  <span class="btn btn-ghost btn-sm btn-disabled" aria-disabled="true">Prev</span>
  {{end}}
  <span class="text-sm text-base-content/70">Page {{.Page}} / {{.TotalPages}}</span>
  {{if .NextHref}}
  <a href="{{.NextHref}}" class="btn btn-ghost btn-sm">Next</a>
  {{else}}
  <span class="btn btn-ghost btn-sm btn-disabled" aria-disabled="true">Next</span>
  {{end}}
</div>
{{end}}
